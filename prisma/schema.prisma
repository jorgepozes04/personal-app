generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  SAVINGS
  WALLET
  CREDIT_CARD
  INVESTMENT
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  PAID
}

enum RecurrenceFrequency {
  MONTHLY
  WEEKLY
  YEARLY
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts              Account[]
  categories            Category[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  authAccounts          AuthAccount[]
  sessions              Session[]

  @@map("users")
}

model Account {
  id             String      @id @default(cuid())
  userId         String
  name           String
  type           AccountType
  initialBalance Decimal     @default(0) @db.Decimal(12, 2)
  currency       String      @default("BRL")
  archived       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]

  @@index([userId])
  @@map("accounts")
}

model Category {
  id        String          @id @default(cuid())
  userId    String? // null = default/system category
  name      String
  type      TransactionType
  color     String?
  icon      String?
  isDefault Boolean         @default(false)
  archived  Boolean         @default(false)
  createdAt DateTime        @default(now())

  user                  User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]

  @@index([userId])
  @@map("categories")
}

model Transaction {
  id                     String            @id @default(cuid())
  userId                 String
  accountId              String
  categoryId             String
  type                   TransactionType
  amount                 Decimal           @db.Decimal(12, 2)
  description            String
  date                   DateTime // effective/due date
  status                 TransactionStatus @default(PENDING)
  paidAt                 DateTime?
  recurringTransactionId String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  account              Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category             Category              @relation(fields: [categoryId], references: [id])
  recurringTransaction RecurringTransaction? @relation(fields: [recurringTransactionId], references: [id])

  @@index([userId, date])
  @@index([accountId])
  @@map("transactions")
}

model RecurringTransaction {
  id         String              @id @default(cuid())
  userId     String
  accountId  String
  categoryId String
  type       TransactionType
  name       String
  amount     Decimal             @db.Decimal(12, 2)
  frequency  RecurrenceFrequency @default(MONTHLY)
  dueDay     Int // day of month (1-31) for MONTHLY
  startDate  DateTime
  endDate    DateTime?
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@map("recurring_transactions")
}

model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
